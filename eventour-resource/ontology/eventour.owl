    skos:inScheme evt:EventourCategoryScheme ;
    skos:prefLabel "performing arts entertainment" ;
    skos:topConceptOf evt:EventourCategoryScheme .

<http://eventour.unimib.it/category/public-art> a skos:Concept ;
    skos:inScheme evt:EventourCategoryScheme ;
    skos:prefLabel "public art" ;
    skos:topConceptOf evt:EventourCategoryScheme .

