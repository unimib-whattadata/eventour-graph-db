<http://eventour.unimib.it/scheme/charging-infrastructure> a skos:ConceptScheme ;
    rdfs:label "Charging infrastructure concept scheme"@en ;
    skos:hasTopConcept <http://eventour.unimib.it/charging-infrastructure/ac-normal> ;
    skos:prefLabel "Charging infrastructure values"@en .

<http://eventour.unimib.it/scheme/charging-typology> a skos:ConceptScheme ;
    rdfs:label "Charging typology concept scheme"@en ;
    skos:hasTopConcept <http://eventour.unimib.it/charging-typology/f>,
        <http://eventour.unimib.it/charging-typology/n>,
        <http://eventour.unimib.it/charging-typology/q>,
        <http://eventour.unimib.it/charging-typology/qn> ;
    skos:prefLabel "Charging typology values"@en .

