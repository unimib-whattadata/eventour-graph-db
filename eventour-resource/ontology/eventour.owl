    skos:prefLabel "Context Entity"@en ;
    skos:topConceptOf evt:CurationLabelScheme .

<http://eventour.unimib.it/curation-label/primary-poi> a skos:Concept ;
    skos:inScheme evt:CurationLabelScheme ;
    skos:prefLabel "Primary POI"@en ;
    skos:topConceptOf evt:CurationLabelScheme .

<http://eventour.unimib.it/curation-label/secondary-poi> a skos:Concept ;
