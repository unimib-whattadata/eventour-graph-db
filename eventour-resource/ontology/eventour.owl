    skos:prefLabel "Secondary POI"@en ;
    skos:topConceptOf evt:CurationLabelScheme .

<http://eventour.unimib.it/role/context-entity> a skos:Concept ;
    skos:definition "Geolocated entity that provides semantic background for the urban knowledge graph but is not treated as a candidate destination or redistribution anchor."@en,
        "Geolocated entity that provides urban context but is not treated as a candidate destination or redistribution anchor."@en ;
    skos:inScheme evt:EventourRoleScheme ;
    skos:prefLabel "Context Entity"@en ;
    skos:topConceptOf evt:EventourRoleScheme .

<http://eventour.unimib.it/role/primary-poi> a skos:Concept ;
    skos:definition "Culturally or historically salient urban place that can act as a destination anchor for itinerary generation, cultural promotion, and event-tourism applications."@en,
        "Culturally or historically salient urban place usable as a destination anchor."@en ;
    skos:inScheme evt:EventourRoleScheme ;
    skos:prefLabel "Primary POI"@en ;
    skos:topConceptOf evt:EventourRoleScheme .

<http://eventour.unimib.it/role/secondary-poi> a skos:Concept ;
    skos:definition "Non-primary geolocated urban place candidate that can support operational tasks such as crowd redistribution, alternative routing, local discovery, or post-event staggering."@en,
        "Non-primary geolocated urban place candidate usable for operational tasks such as crowd redistribution or alternative routing."@en ;
    skos:inScheme evt:EventourRoleScheme ;
    skos:prefLabel "Secondary POI"@en ;
    skos:topConceptOf evt:EventourRoleScheme .

evt:AdministrativeArea a owl:Class ;
    rdfs:label "Administrative area"@en ;
    rdfs:subClassOf geo:Feature .

evt:StreetFurniture a owl:Class ;
    rdfs:label "Street furniture"@en ;
    rdfs:subClassOf evt:PhysicalAsset .

evt:Infrastructure a owl:Class ;
    rdfs:label "Infrastructure"@en ;
    rdfs:subClassOf evt:PhysicalAsset .

evt:Place a owl:Class ;
    rdfs:label "Place"@en ;
    rdfs:comment "Geolocated place entity in the Eventour semantic place layer."@en ;
    rdfs:subClassOf evt:UrbanPlace .

evt:PhysicalAsset a owl:Class ;
    rdfs:label "Physical asset"@en ;
    rdfs:subClassOf evt:UrbanThing,
        geo:Feature .

evt:UrbanEntity a owl:Class ;
    rdfs:label "Urban entity"@en ;
    rdfs:comment "Top-level class for entities represented in an Eventour city knowledge graph."@en .

evt:TransportEntity a owl:Class ;
    rdfs:label "Transport entity"@en ;
    rdfs:subClassOf evt:UrbanThing .

evt:CurationLabelScheme a skos:ConceptScheme ;
    skos:hasTopConcept <http://eventour.unimib.it/curation-label/context-entity>,
        <http://eventour.unimib.it/curation-label/primary-poi>,
        <http://eventour.unimib.it/curation-label/secondary-poi> ;
    skos:prefLabel "Eventour curation label scheme"@en .

evt:EventourRoleScheme a skos:ConceptScheme ;
    skos:hasTopConcept <http://eventour.unimib.it/role/context-entity>,
        <http://eventour.unimib.it/role/primary-poi>,
        <http://eventour.unimib.it/role/secondary-poi> ;
    skos:prefLabel "Eventour role scheme"@en .

evt:UrbanThing a owl:Class ;
    rdfs:label "Urban thing"@en ;
    rdfs:subClassOf evt:UrbanEntity .

evt:Facility a owl:Class ;
    rdfs:label "Facility"@en ;
    rdfs:subClassOf evt:PhysicalAsset .

evt:ServiceAccessPoint a owl:Class ;
    rdfs:label "Service access point"@en ;
    rdfs:subClassOf evt:UrbanThing .

evt:EventourCategoryScheme a skos:ConceptScheme ;
    skos:hasTopConcept <http://eventour.unimib.it/category/archaeological-ancient-site>,
        <http://eventour.unimib.it/category/cemetery-funerary-heritage>,
        <http://eventour.unimib.it/category/district-streetscape>,
        <http://eventour.unimib.it/category/gallery-art-space>,
        <http://eventour.unimib.it/category/historic-architecture>,
        <http://eventour.unimib.it/category/monument-memorial>,
        <http://eventour.unimib.it/category/museum-collection>,
        <http://eventour.unimib.it/category/park-garden-nature>,
        <http://eventour.unimib.it/category/performing-arts-entertainment>,
        <http://eventour.unimib.it/category/public-art>,
        <http://eventour.unimib.it/category/religious-heritage>,
        <http://eventour.unimib.it/category/science-education-attraction>,
        <http://eventour.unimib.it/category/special-interest-attraction>,
        <http://eventour.unimib.it/category/urban-landmark> ;
    skos:prefLabel "Eventour category scheme"@en .
