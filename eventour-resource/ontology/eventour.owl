@prefix dct: <http://purl.org/dc/terms/> .
@prefix evt: <http://eventour.unimib.it/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

evt:Bench a owl:Class ;
    rdfs:label "Bench"@en ;
    rdfs:subClassOf evt:StreetFurniture .

evt:BicycleParkingArea a owl:Class ;
    rdfs:label "Bicycle parking area"@en ;
    rdfs:subClassOf evt:Facility .

evt:BikeSharingStation a owl:Class ;
    rdfs:label "Bike-sharing station"@en ;
    rdfs:subClassOf evt:Facility,
        evt:ServiceAccessPoint .

evt:DrinkingFountain a owl:Class ;
    rdfs:label "Drinking fountain"@en ;
    rdfs:subClassOf evt:Infrastructure,
        evt:ServiceAccessPoint .

evt:EVChargingStation a owl:Class ;
    rdfs:label "EV charging station"@en ;
    rdfs:subClassOf evt:Facility,
        evt:Infrastructure,
        evt:ServiceAccessPoint .

evt:EventourOntology a owl:Ontology ;
    rdfs:label "Eventour ontology"@en ;
    dct:description "Ontology for the Eventour multi-layer urban knowledge graph, covering municipal urban infrastructure, mobility and service layers, and a role-based semantic place layer."@en ;
    owl:versionInfo "2026-05-03" .

evt:GeometrySample a owl:Class ;
    rdfs:label "Geometry sample"@en .

evt:HistoricShop a owl:Class ;
    rdfs:label "Historic shop"@en ;
    rdfs:subClassOf evt:Facility .

evt:InterchangeParkingFacility a owl:Class ;
    rdfs:label "Interchange parking facility"@en ;
    rdfs:subClassOf evt:ParkingFacility .

evt:MetroStation a owl:Class ;
    rdfs:label "Metro station"@en ;
    rdfs:subClassOf evt:Stop .

evt:Municipality a owl:Class ;
    rdfs:label "Municipality"@en ;
    rdfs:subClassOf evt:AdministrativeArea .

evt:NILArea a owl:Class ;
    rdfs:label "Nucleo di Identità Locale area"@en ;
    rdfs:subClassOf evt:AdministrativeArea .

evt:ParkingFacility a owl:Class ;
    rdfs:label "Parking facility"@en ;
    rdfs:subClassOf evt:Facility,
        evt:ServiceAccessPoint .

evt:PicnicTable a owl:Class ;
    rdfs:label "Picnic table"@en ;
    rdfs:subClassOf evt:StreetFurniture .

evt:Project a owl:Class ;
    rdfs:label "Project"@en ;
    rdfs:subClassOf evt:UrbanThing .

evt:PublicToilet a owl:Class ;
    rdfs:label "Public toilet"@en ;
    rdfs:subClassOf evt:Facility,
        evt:ServiceAccessPoint .

evt:RoutePattern a owl:Class ;
    rdfs:label "Route pattern"@en ;
    rdfs:subClassOf evt:TransportEntity,
        geo:Feature .

evt:Service a owl:Class ;
    rdfs:label "Service"@en ;
    rdfs:subClassOf evt:UrbanThing .

evt:ServicePattern a owl:Class ;
    rdfs:label "Service pattern"@en ;
    rdfs:subClassOf evt:TransportEntity .

evt:SourceRecord a owl:Class ;
    rdfs:label "Source record"@en ;
    rdfs:subClassOf prov:Entity .

evt:Stop a owl:Class ;
    rdfs:label "Transit stop"@en ;
    rdfs:subClassOf evt:Facility,
        evt:ServiceAccessPoint .

evt:StopInRoute a owl:Class ;
    rdfs:label "Stop in route"@en ;
    rdfs:subClassOf evt:TransportEntity .

evt:Street a owl:Class ;
    rdfs:label "Street"@en ;
    rdfs:subClassOf evt:UrbanThing .

evt:TimetableSummary a owl:Class ;
    rdfs:label "Timetable summary"@en ;
    rdfs:subClassOf evt:TransportEntity .

evt:TransitLine a owl:Class ;
    rdfs:label "Transit line"@en ;
    rdfs:subClassOf evt:TransportEntity .

evt:Tree a owl:Class ;
    rdfs:label "Tree"@en ;
    rdfs:subClassOf evt:PhysicalAsset .

evt:WiFiAccessPoint a owl:Class ;
    rdfs:label "Wi-Fi access point"@en ;
    rdfs:subClassOf evt:Infrastructure,
        evt:ServiceAccessPoint .

