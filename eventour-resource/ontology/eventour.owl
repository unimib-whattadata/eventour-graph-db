evt:hasCurationLabel a owl:ObjectProperty,
        rdf:Property ;
    rdfs:label "has curation label"@en ;
    rdfs:comment "Stores the normalized curation label assigned during semantic place curation."@en ;
    rdfs:domain evt:Place ;
    rdfs:range skos:Concept .

evt:hasEventourCategory a owl:ObjectProperty,
        rdf:Property ;
    rdfs:label "has Eventour category"@en ;
    rdfs:comment "Associates a primary or secondary place with a semantic Eventour category."@en ;
    rdfs:domain evt:Place ;
    rdfs:range skos:Concept .

evt:hasEventourRole a owl:ObjectProperty,
        rdf:Property ;
    rdfs:label "has Eventour role"@en ;
    rdfs:comment "Associates a semantic place with its application role in Eventour."@en ;
    rdfs:domain evt:Place ;
    rdfs:range skos:Concept .

evt:hasGeometrySample a rdf:Property ;
    rdfs:label "has geometry sample"@en .

evt:hasPrimaryFamily a owl:ObjectProperty,
        rdf:Property ;
    rdfs:label "has primary family"@en ;
    rdfs:comment "Links an entity to its broad Eventour family."@en ;
    rdfs:domain evt:UrbanEntity ;
    rdfs:range owl:Class .

evt:hasSecondaryFamily a owl:ObjectProperty,
        rdf:Property ;
    rdfs:label "has secondary family"@en ;
    rdfs:comment "Links an entity to an additional Eventour family when applicable."@en ;
    rdfs:domain evt:UrbanEntity ;
    rdfs:range owl:Class .

