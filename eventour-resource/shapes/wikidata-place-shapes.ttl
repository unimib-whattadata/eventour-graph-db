@prefix dct: <http://purl.org/dc/terms/> .
@prefix evt: <http://eventour.unimib.it/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

evt:SpatialFeatureShape a sh:NodeShape ;
    rdfs:label "Eventour spatial feature shape"@en ;
    sh:targetClass geo:Feature ;
    sh:property [
            sh:path geo:hasGeometry ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:class geo:Geometry ;
            sh:message "Every Eventour spatial feature must have at least one GeoSPARQL geometry."@en
        ],
        [
            sh:path geo:hasDefaultGeometry ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:class geo:Geometry ;
            sh:message "Every Eventour spatial feature must have exactly one default geometry."@en
        ],
        [
            sh:path dct:source ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:message "Every Eventour spatial feature must point to its source dataset."@en
        ],
        [
            sh:path prov:wasDerivedFrom ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:message "Every Eventour spatial feature must preserve derivation provenance."@en
        ],
        [
            sh:path rdfs:label ;
            sh:minCount 1 ;
            sh:severity sh:Warning ;
            sh:message "Every Eventour spatial feature should have a human-readable label."@en
        ] .

evt:GeometryShape a sh:NodeShape ;
    rdfs:label "Eventour geometry shape"@en ;
    sh:targetClass geo:Geometry ;
    sh:property [
            sh:path geo:asWKT ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:datatype geo:wktLiteral ;
            sh:message "Every Eventour geometry must have exactly one GeoSPARQL WKT literal."@en
        ] .

evt:WikidataPlaceShape a sh:NodeShape ;
    rdfs:label "Eventour Wikidata place shape"@en ;
    sh:targetClass evt:Place ;
    sh:property [
            sh:path evt:hasEventourRole ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:in (
                <http://eventour.unimib.it/role/primary-poi>
                <http://eventour.unimib.it/role/secondary-poi>
                <http://eventour.unimib.it/role/context-entity>
            ) ;
            sh:message "Every Eventour semantic place must have exactly one valid Eventour role."@en
        ],
        [
            sh:path owl:sameAs ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:pattern "^http://www\\.wikidata\\.org/entity/Q[0-9]+$" ;
            sh:message "Every Wikidata-derived Eventour place must link back to its Wikidata entity."@en
        ],
        [
            sh:path geo:hasDefaultGeometry ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:message "Every Wikidata-derived Eventour place must have one default geometry."@en
        ],
        [
            sh:path evt:inNIL ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:class evt:NILArea ;
            sh:message "Every published Wikidata-derived Eventour place must be assigned to exactly one NIL area."@en
        ],
        [
            sh:path dct:source ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:message "Every Wikidata-derived Eventour place must have source metadata."@en
        ],
        [
            sh:path prov:wasDerivedFrom ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:message "Every Wikidata-derived Eventour place must preserve derivation provenance."@en
        ],
        [
            sh:path rdfs:label ;
            sh:minCount 1 ;
            sh:message "Every Wikidata-derived Eventour place must have a human-readable label."@en
        ] .

evt:EventourRoleConceptShape a sh:NodeShape ;
    rdfs:label "Eventour role concept shape"@en ;
    sh:targetObjectsOf evt:hasEventourRole ;
    sh:property [
            sh:path rdf:type ;
            sh:hasValue skos:Concept ;
            sh:message "Every Eventour role must be represented as a SKOS concept."@en
        ],
        [
            sh:path skos:inScheme ;
            sh:hasValue evt:EventourRoleScheme ;
            sh:message "Every Eventour role concept must belong to the Eventour role scheme."@en
        ],
        [
            sh:path skos:prefLabel ;
            sh:minCount 1 ;
            sh:message "Every Eventour role concept must have a preferred label."@en
        ] .

evt:SourceRecordShape a sh:NodeShape ;
    rdfs:label "Eventour source record shape"@en ;
    sh:targetClass evt:SourceRecord ;
    sh:property [
            sh:path evt:sourceIdentifierField ;
            sh:minCount 1 ;
            sh:message "Every source record should preserve the source identifier field name."@en
        ],
        [
            sh:path evt:sourceIdentifierValue ;
            sh:minCount 1 ;
            sh:message "Every source record should preserve the source identifier value."@en
        ] .

evt:NILLinkedFeatureShape a sh:NodeShape ;
    rdfs:label "Eventour NIL-linked feature shape"@en ;
    sh:targetClass geo:Feature ;
    sh:property [
            sh:path evt:inNIL ;
            sh:minCount 1 ;
            sh:severity sh:Warning ;
            sh:message "Spatial features should be linked to a NIL area when spatial inference is available."@en
        ] .
