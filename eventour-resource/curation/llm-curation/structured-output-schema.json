{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["decision", "eventour_category", "confidence", "rationale"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["keep_poi", "keep_context", "candidate_exception", "exclude"]
    },
    "eventour_category": {
      "type": ["string", "null"],
      "enum": [
        "museum_collection",
        "gallery_art_space",
        "religious_heritage",
        "historic_architecture",
        "monument_memorial",
        "public_art",
        "archaeological_ancient_site",
        "urban_landmark",
        "performing_arts_entertainment",
        "park_garden_nature",
        "cemetery_funerary_heritage",
        "science_education_attraction",
        "district_streetscape",
        "special_interest_attraction",
        null
      ]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "rationale": {"type": "string"}
  }
}

